# Copy to .env and uncomment what you need:  cp .env.example .env
# Variables already set in the real environment take precedence over .env.

# --- Core ---
# PORT=8787
# HOST=127.0.0.1                 # keep local; expose via `tailscale serve`
# PUBLIC_URL=                    # e.g. https://your-machine.your-tailnet.ts.net (shown in the QR)
# PROJECT_DIR=                   # default working directory for new sessions
# AGENT=claude                  # claude | codex | antigravity

# --- Access token (recommended when reachable beyond localhost) ---
# ACCESS_TOKEN=                  # e.g. output of: openssl rand -hex 16

# --- Agent binaries ---
# CLAUDE_BIN=claude
# CODEX_BIN=codex
# AGY_BIN=agy
# CODEX_CONTINUE_ARGS=          # opt-in Codex resume, e.g. "resume --last"
# AGY_CONTINUE_ARGS=            # opt-in Antigravity resume
# AGENT_TIMEOUT_MS=1200000      # per-turn cap before the agent is killed (default 20 min). 0 = no cap (for long autonomous tasks; stop via the app/closing the tab).

# --- Speech-to-text ---
# STT_MODE=browser              # browser | whisper
# STT_CMD=                      # whisper mode: command; {file} = recorded audio path

# --- Sessions ---
# SESSIONS_FILE=                # e.g. ~/.voicebridge/sessions.json (persist across restarts)
# MAX_SESSIONS=200
# FAVORITES=                    # JSON array, e.g. [{"name":"App","projectDir":"/path","agent":"claude"}]

# --- Cloud runner ---
# CLOUD_RUNNER_URL=             # http(s) endpoint that speaks the NDJSON protocol
# CLOUD_RUNNER_TOKEN=

# --- Web Push (real OS notifications) ---  generate with: node scripts/gen-vapid-keys.js
# VAPID_PUBLIC_KEY=
# VAPID_PRIVATE_KEY=
# VAPID_SUBJECT=mailto:you@example.com
